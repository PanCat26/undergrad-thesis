aws_region  = "eu-central-1"
environment = "prod"

# Your public domain.
domain        = "app.example.com"
callback_urls = ["https://app.example.com"]
logout_urls   = ["https://app.example.com"]

# Host sizing + access.
instance_type  = "t3.small"
ssh_allow_cidr = "203.0.113.4/32" # your IP/32; or rely on SSM and leave SSH unused
key_name       = ""               # an existing EC2 key pair name, or "" for SSM-only access

# Optional: pin a globally-unique bucket name (otherwise derived from the account id).
# sources_bucket_name = "research-tool-prod-sources"
