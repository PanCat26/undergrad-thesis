# Production environment for the single-EC2 deployment.
# Copy to .env.prod on the server, fill in real values, and run:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
# Keep this file out of version control and chmod 600 it.

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
APP_ENV=prod
LOG_LEVEL=INFO

# Public domain (used by Caddy for TLS, by CORS, and by the frontend build).
DOMAIN=app.example.com
ACME_EMAIL=you@example.com
CORS_ORIGINS=https://app.example.com
NEXT_PUBLIC_API_BASE_URL=https://app.example.com

# ---------------------------------------------------------------------------
# PostgreSQL (container on this host; data in the postgres_data volume)
# ---------------------------------------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=app
DATABASE_URL=postgresql+asyncpg://app:CHANGE_ME_STRONG@postgres:5432/app

# ---------------------------------------------------------------------------
# Qdrant (container on this host; data in the qdrant_data volume)
# ---------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ---------------------------------------------------------------------------
# Source storage = S3. Leave AWS keys EMPTY to use the EC2 instance role.
# ---------------------------------------------------------------------------
STORAGE_BACKEND=s3
S3_BUCKET=research-tool-prod-sources
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Cognito (prod user pool — from `terraform output`)
# ---------------------------------------------------------------------------
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Guest sessions — MUST be a strong, unique secret (the app refuses to start otherwise).
# ---------------------------------------------------------------------------
GUEST_TOKEN_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
GUEST_TOKEN_TTL_MINUTES=720

# ---------------------------------------------------------------------------
# OpenAI / agent
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Second selectable OpenAI model shown in Settings (defaults to gpt-5.4-mini; override to change).
OPENAI_ALT_MODEL=gpt-5.4-mini
OPENAI_ALT_LABEL=gpt-5.4-mini
CITATION_LOOKUP_ENABLED=true
CITATION_LOOKUP_TIMEOUT=10

# ---------------------------------------------------------------------------
# Abuse guardrails (counters stored in Postgres). Tune the global daily LLM ceiling.
# ---------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=db
GLOBAL_DAILY_AGENT_RUNS=2000

# Number of uvicorn workers in the backend container.
UVICORN_WORKERS=2
