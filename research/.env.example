# Copy to research/.env and fill in. Auto-loaded by the eval suite (eval/__init__.py).
# research/.env is gitignored — never commit real keys.

OPENAI_API_KEY=sk-...          # the agent under test (gpt-4.1-mini / gpt-5.4-mini)
ANTHROPIC_API_KEY=sk-ant-...   # the DeepEval judge (claude-sonnet-4-6)

# Optional knobs (defaults shown):
# EVAL_TEMPERATURE=0               # default 0 = deterministic, reproducible, matches the deployed agent
# EVAL_LOCAL_BASE_URL=http://localhost:8000/v1   # where the served Qwen variants listen
