# Copy to .env and fill in. APP_ENV switches dev/prod behaviour across the stack.
# Variables are consumed by docker-compose and passed into the backend/frontend containers.

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
APP_ENV=dev
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Backend HTTP
# ---------------------------------------------------------------------------
BACKEND_PORT=8000
# Comma-separated list of allowed CORS origins (the frontend dev origin).
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# PostgreSQL (local container in dev; RDS in prod)
# ---------------------------------------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
# Async SQLAlchemy URL used by the backend. Host "postgres" is the compose service.
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/app

# ---------------------------------------------------------------------------
# Qdrant (local container in dev; Qdrant Cloud in prod) — used from Phase 3
# ---------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=source_chunks

# ---------------------------------------------------------------------------
# Source storage (local disk in dev; S3 in prod) — used from Phase 3
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/data/sources
S3_BUCKET=
MAX_UPLOAD_MB=25

# ---------------------------------------------------------------------------
# AWS Cognito (real dev user pool now; separate prod pool later)
# Create the dev pool with infra/terraform, then paste the outputs here.
# ---------------------------------------------------------------------------
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
# Leave empty if the app client has no secret (the default Terraform creates one without).
COGNITO_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Guest sessions (backend-signed token, not a Cognito user)
# ---------------------------------------------------------------------------
GUEST_TOKEN_SECRET=change-me-in-prod
GUEST_TOKEN_TTL_MINUTES=720

# ---------------------------------------------------------------------------
# OpenAI (embeddings are used from Phase 3; the chat model from Phase 4)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
# Base URL the browser uses to reach the backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
